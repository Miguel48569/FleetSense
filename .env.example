# FleetSense - Variáveis de Ambiente
# Copie este arquivo para .env e configure os valores

# URL base do backend (sem barra no final)
# Exemplo: http://localhost:8000/api
# Se não definida, o frontend usa localStorage como fallback
VITE_API_URL=

# Título da aplicação (opcional)
VITE_APP_TITLE=FleetSense
